-- =========================

-- queries de consulta

-- =========================



-- listar clientes

select * from cliente order by nome asc;



-- buscar consultas de um cliente

select * from consulta

where id_cliente = 1;



-- médicos ativos

select * from listagem_medica

where ativo = true;



-- cliente + observações

select c.nome, co.observacoes

from cliente c

join consulta co on c.cliente_id = co.id_cliente;



-- clínicas e conformidade

select cl.nome, cf.segue_normas

from clinica cl

join conformidade_legal cf on cl.clinica_id = cf.id_clinica;



-- agenda ordenada

select * from agendamento

order by dataagendada asc;
