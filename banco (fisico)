create table listagem_medica (

    listagem_id serial primary key,

    nome varchar(150) not null,

    cpf varchar(11) unique not null

        check (cpf ~ '^[0-9]{11}$'),

    crm varchar(20) unique not null,

    telefone varchar(11)

        check (telefone ~ '^[0-9]{10,11}$'),

    email varchar(150) unique,

    data_nascimento date,

    ativo boolean default true

);



create table agendamento (

    agendamento_id serial primary key,

    dataagendada timestamp not null,

    informacoesatendimento text

);



create table cliente (

    cliente_id serial primary key,

    nome varchar(150) not null,

    idade int,

    cpf varchar(11) unique not null

        check (cpf ~ '^[0-9]{11}$'),

    email varchar(150) unique,

    numerotelefone varchar(11)

        check (numerotelefone ~ '^[0-9]{10,11}$'),

    endereco varchar(255),

    prontuario text

);



create table farmacia (

    farmacia_id serial primary key,

    nome varchar(150) not null,

    cnpj varchar(14) unique not null

        check (cnpj ~ '^[0-9]{14}$'),

    telefone varchar(11)

        check (telefone ~ '^[0-9]{10,11}$'),

    endereco varchar(255)

);



create table clinica (

    clinica_id serial primary key,

    nome varchar(150) not null,

    cnpj varchar(14) unique not null

        check (cnpj ~ '^[0-9]{14}$'),

    endereco varchar(255),

    numerotelefone varchar(11)

        check (numerotelefone ~ '^[0-9]{10,11}$'),

    id_listagem integer,

    constraint fk_clinica_listagem

        foreign key (id_listagem)

        references listagem_medica(listagem_id)

);



create table conformidade_legal (

    conformidadelegal_id serial primary key,

    id_clinica integer not null,

    segue_normas boolean default false,

    data_verificacao date,

    observacao text,

    constraint fk_conformidade_clinica

        foreign key (id_clinica)

        references clinica(clinica_id)

        on delete cascade

);



create table consulta (

    consulta_id serial primary key,

    observacoes text,

    id_clinica integer not null,

    id_cliente integer not null,

    id_agendamento integer not null,

    constraint fk_consulta_clinica

        foreign key (id_clinica)

        references clinica(clinica_id),

    constraint fk_consulta_cliente

        foreign key (id_cliente)

        references cliente(cliente_id),

    constraint fk_consulta_agendamento

        foreign key (id_agendamento)

        references agendamento(agendamento_id)

);



